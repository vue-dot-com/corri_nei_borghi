<configuration>
  <!--
    Cache policy.

    Default for the whole site (pages, CSS, JS, JSON data, HTML fragments):
    the browser may keep a copy but must revalidate it on every load, so a
    deploy is visible immediately. Unchanged files answer with a 304 and cost
    almost nothing, changed files are downloaded again.
  -->
  <system.webServer>
    <staticContent>
      <clientCache cacheControlMode="DisableCache" />
    </staticContent>
  </system.webServer>

  <location path="public" inheritInChildApplications="false">
    <system.webServer>
      <staticContent>
        <mimeMap fileExtension=".md" mimeType="text/plain" />
        <mimeMap fileExtension=".webp" mimeType="image/webp" />
        <!-- style.css lives here and must follow the site default, not the
             long cache used for the binary assets below -->
        <clientCache cacheControlMode="DisableCache" />
      </staticContent>
    </system.webServer>
  </location>

  <!--
    Images, photos and PDFs are heavy and almost always added under a new
    name rather than replaced, so they keep a long cache. 30 days instead of
    a year keeps the site fast while bounding how long a re-uploaded file
    can stay stale.
  -->
  <location path="public/images" inheritInChildApplications="false">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="30.00:00:00" />
      </staticContent>
    </system.webServer>
  </location>

  <location path="public/media" inheritInChildApplications="false">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="30.00:00:00" />
      </staticContent>
    </system.webServer>
  </location>

  <location path="public/files" inheritInChildApplications="false">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="30.00:00:00" />
      </staticContent>
    </system.webServer>
  </location>
</configuration>
